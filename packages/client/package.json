{
  "name": "@billionsnetwork/x402-human-proof-client",
  "version": "0.1.0",
  "license": "UNLICENSED",
  "description": "Client helper for agent-side HUMAN-PROOF signing — wraps CAIP-122 challenge/response for EVM agents",
  "type": "module",
  "main": "./dist/node/cjs/index.cjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "node": {
        "import": "./dist/node/esm/index.js",
        "require": "./dist/node/cjs/index.cjs"
      },
      "browser": "./dist/browser/esm/index.js",
      "umd": "./dist/browser/umd/index.global.js"
    }
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup --config tsup.config.ts && tsc --emitDeclarationOnly --declaration --declarationMap --outDir dist/types",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "bs58": "^6.0.0",
    "@0xpolygonid/js-sdk": "^1.43.0",
    "@iden3/js-iden3-core": "^1.8.0",
    "@x402/core": "^2.9.0"
  }
}